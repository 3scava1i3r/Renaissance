# === Blockchain ===
BSC_RPC=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
PRIVATE_KEY=0x...
AGENT_WALLET=0x...

# === CoinMarketCap Agent Hub ===
CMC_API_KEY=your_cmc_pro_api_key_here
CMC_MCP_ENABLED=true

# === Trust Wallet Agent Kit (TWAK) ===
# Get credentials at: https://portal.trustwallet.com
TWAK_ACCESS_ID=your_twak_access_id
TWAK_HMAC_SECRET=your_twak_hmac_secret

# === Natural Language Strategy ===
# Describe your trading strategy in plain English
# Examples:
#   "long ETH perps when funding negative and RSI < 30, 5x, $200 max"
#   "short BTC when RSI > 70, 3x leverage, 20% drawdown limit"
STRATEGY_NL=long ETH perps when funding negative and RSI < 30, 5x leverage, max 30% drawdown, $200 per trade

# === Smart Contract ===
VAULT_ADDRESS=0x...

# === AI ===
VENICE_API_KEY=your_venice_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Dashboard ===
PORT=3000

# === Agent Rules ===
MAX_DRAWDOWN_PCT=30
MIN_TRADES_PER_DAY=1
MAX_LEVERAGE=5
MAX_POSITION_PCT=20
CYCLE_INTERVAL_MS=1800000
